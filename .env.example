DATABASE_URL=postgres://user:pass@localhost:5432/pointage
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id

# Mode developpement : bypass l'auth JWT et utilise un user mock
# Mettre a "true" pour tester sans token Entra ID
DEV_AUTH_BYPASS=false
DEV_USER_OID=your-entra-oid
DEV_USER_NAME=Dev User
DEV_USER_EMAIL=dev@localhost

# Clé API pour le sync n8n → POST /api/projects/sync
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SYNC_API_KEY=
